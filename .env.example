# Optional paths that enable the integration tests (`dotnet test`).
# Copy this file to `.env` and set the paths for your machine. `.env` is
# git-ignored. Any value left unset (or pointing at a missing path) makes the
# tests that need it no-op, so the unit-test suite stays green without them.
#
# Process environment variables of the same name take precedence over `.env`,
# so CI can override these without editing the file.

# EU4 game install directory (must contain common/, events/, localisation/).
EU4_GAME_DIR=/path/to/Europa Universalis IV

# CWTools EU4 config rules repo (a cwtools-eu4-config checkout).
EU4_CONFIG_DIR=/path/to/cwtools-eu4-config

# An example mod directory (drives the override + special-escape loc tests).
EU4_EXAMPLE_MOD_DIR=/path/to/example_eu4_mod

# --- HOI4 integration test (optional) ---
# Enables Hoi4IntegrationTests against a real Hearts of Iron IV install. The
# config defaults to the one fetched by `eu4indexer setup`
# (~/.eu4indexer/config/hoi4); set HOI4_CONFIG_DIR to override it.
# HOI4_EXAMPLE_MOD_DIR additionally enables the HOI4 override test. All optional —
# the tests no-op when unset.
# HOI4_GAME_DIR=/path/to/Hearts of Iron IV
# HOI4_CONFIG_DIR=/path/to/cwtools-hoi4-config
# HOI4_EXAMPLE_MOD_DIR=/path/to/example_hoi4_mod

# PostgreSQL connection string for the Postgres export test. When set (together
# with the game + config dirs), the test builds the index into both SQLite and
# this database and compares them. The role needs CREATE EXTENSION pg_trgm.
# Leave unset to skip the test.
# EU4_PG_CONN=Host=localhost;Database=eu4_export_test;Username=postgres;Password=postgres
